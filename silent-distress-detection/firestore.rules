rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For the "Silent Distress Detection" prototype:
    // We allow read/write to the 'alerts' collection.
    // In production, restrict this to authenticated services only.
    
    match /alerts/{alertId} {
      allow read, write: if true; // Open for Demo/Hackathon ease. Lock down in Prod.
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
